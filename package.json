{
  "name": "@lcm2m/caddis-mcp",
  "version": "0.2.1",
  "description": "MCP server for the LCM2M Caddis VMCP API",
  "license": "MIT",
  "author": "LCM2M",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LCM2M/lcm2m-caddis-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/LCM2M/lcm2m-caddis-mcp/issues"
  },
  "homepage": "https://github.com/LCM2M/lcm2m-caddis-mcp#readme",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "lcm2m",
    "caddis",
    "llm",
    "claude",
    "anthropic"
  ],
  "bin": {
    "caddis-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "mcp-inspector tsx --env-file=.env.local src/index.ts",
    "start": "node dist/index.js",
    "test": "tsx --test src/client.test.ts src/tools/schemas.test.ts src/tools/registry.test.ts src/tools/composite/batch.test.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "docker:build": "docker build --target runtime -t lcm2m-caddis-mcp .",
    "preversion": "npm run typecheck && npm run lint && npm test",
    "postversion": "git push --follow-tags",
    "prepublishOnly": "npm run typecheck && npm run lint && npm test && npm run build",
    "release:patch": "npm version patch && npm publish",
    "release:minor": "npm version minor && npm publish",
    "release:major": "npm version major && npm publish"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@modelcontextprotocol/inspector": "^0.18.0",
    "@types/node": "^25.0.0",
    "tsx": "^4.20.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=25"
  }
}
